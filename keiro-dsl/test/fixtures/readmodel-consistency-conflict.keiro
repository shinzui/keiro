context hospital-capacity

readmodel transfer_decisions {
  table = "transfer_decisions"
  schema = "hospital_capacity"
  columns {
    reservation_id text required
  }
  version = 1
  shape = "fnv1a:d44d218822582783"
  consistency = Strong
  feed = subscription
}

aggregate Reservation
  regs
  states Open

  command Reserve { reservationId }
  event Reserved = fields(Reserve)

  Open -- Reserve --> emit Reserved ; goto Open

  projection transfer_decisions consistency=Eventual key=reservationId
    status-map { Reserved=>reserved }
