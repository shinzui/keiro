-- Spike-only cabal.project for the codec spike. Same setup as
-- spikes/command-cycle/cabal.project: pin GHC, point at local
-- sister checkouts via optional-packages.

packages:
    spike.cabal

with-compiler: ghc-9.12.3

tests: False
benchmarks: False

