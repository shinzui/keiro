    /Users/shinzui/Keikaku/bokuno/ephemeral-pg-project/ephemeral-pg/ephemeral-pg.cabal
    /Users/shinzui/Keikaku/hub/haskell/hasql-project/hasql-notifications/hasql-notifications.cabal
